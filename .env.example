# OpenAI
OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL=gpt-4.1-mini

# AssemblyAI
ASSEMBLYAI_API_KEY=your_assemblyai_api_key

# Service API Key
SERVICE_API_KEY=your_internal_service_api_key

# Custom list of keywords to look for in the captions
KEYWORDS=ingrediente

# Rate limiting configuration
RATE_LIMIT_DAILY=50
RATE_LIMIT_TIMEZONE=Europe/Madrid
RATE_LIMIT_DB_PATH=data/rate_limits.db
