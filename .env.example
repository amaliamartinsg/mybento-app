# Configuracion no sensible
OPENAI_MODEL=gpt-4.1-mini
KEYWORDS=ingrediente
RATE_LIMIT_DAILY=50
RATE_LIMIT_TIMEZONE=Europe/Madrid
GRAFANA_ADMIN_USER=admin

# Config local opcional
BACKEND_URL=http://localhost:8000
DATABASE_URL=sqlite:///./recipe_manager.db

# Rutas de archivos de secrets para Docker Compose
USDA_API_KEY_FILE_PATH=./.secrets/usda_api_key.txt
UNSPLASH_ACCESS_KEY_FILE_PATH=./.secrets/unsplash_access_key.txt
OPENAI_API_KEY_FILE_PATH=./.secrets/openai_api_key.txt
SCRAPER_API_KEY_FILE_PATH=./.secrets/scraper_api_key.txt
ASSEMBLYAI_API_KEY_FILE_PATH=./.secrets/assemblyai_api_key.txt
GRAFANA_ADMIN_PASSWORD_FILE_PATH=./.secrets/grafana_admin_password.txt
